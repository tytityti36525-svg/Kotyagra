rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helper: розумні межі критичних полів гравця (блокує грубу накрутку) ──
    function numOk(v, maxv) {
      return v == null || (v is number && v >= 0 && v <= maxv);
    }
    function playerValid(d) {
      return numOk(d.coins, 100000000)
        && numOk(d.hearts, 100000000)
        && numOk(d.butterflies, 10000000)
        && numOk(d.crystals, 500000)
        && numOk(d.glamour, 10000000)
        && numOk(d.bank, 100000000)
        && (d.level == null || (d.level is number && d.level >= 1 && d.level <= 999))
        && (d.skillPoints == null || (d.skillPoints is number && d.skillPoints >= 0 && d.skillPoints <= 99999));
    }
    function isMember(clubId) {
      return exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }
    function clubRole(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data().role;
    }

    // Гравець читає/пише лише свій документ + валідація меж
    match /players/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId && playerValid(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId && playerValid(request.resource.data);
      allow delete: if false;
    }

    // Реєстр кристалів — лише сервер (Admin SDK). Клієнту заборонено.
    match /crystalLedger/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /online/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.directorUid == request.auth.uid;
      allow update: if request.auth != null && isMember(clubId);
      allow delete: if request.auth != null && resource.data.directorUid == request.auth.uid;

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (
          request.auth.uid == memberId
          || get(/databases/$(database)/documents/clubs/$(clubId)).data().directorUid == request.auth.uid
          || (isMember(clubId) && clubRole(clubId) in ['deputy','treasurer','officer'])
        );
      }

      match /history/{histId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isMember(clubId);
        allow update, delete: if false;
      }

      match /forum/{topicId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isMember(clubId);
        allow delete: if request.auth != null && isMember(clubId);
        allow update: if false;
        match /posts/{postId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null && isMember(clubId);
          allow delete: if request.auth != null && isMember(clubId);
          allow update: if false;
        }
      }

      match /donations/{donId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /chat/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 300;
      allow update, delete: if false;
    }

    match /mail/{mailId} {
      allow read: if request.auth != null
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 1000;
      allow update: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }
  }
}
